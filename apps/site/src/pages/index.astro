        <script type="module">
            import { createShader, playSweep as glimmPlaySweep } from '/glimm.js';

            console.log(
                '%c🎁 Easter Egg: Screenshot this and email support@touch-ai.org to claim your reward. Limited quantity, first come first served!',
                'color: #ef4444; font-size: 14px; font-weight: bold;'
            );

            var prefersDark =
                window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            var lang =
                localStorage.getItem('ta_lang') ||
                ((navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en');
            var isDark = localStorage.getItem('ta_theme')
                ? localStorage.getItem('ta_theme') === 'dark'
                : prefersDark;
            var labels = { zh: ['天', '时', '分', '秒'], en: ['d', 'h', 'm', 's'] };

            var shader = null;
            var playSweep = null;
            var sweeping = false;

            try {
                shader = createShader();
                playSweep = glimmPlaySweep;
                if (shader && shader.canvas) {
                    var c = shader.canvas;
                    c.style.cssText =
                        'position:fixed;inset:0;width:100vw;height:100vh;pointer-events:none;z-index:9999;';
                    document.body.appendChild(c);
                }
            } catch (e) {
                console.warn('glimm WebGL init failed, transitions disabled:', e);
            }

            function withSweep(callback) {
                if (!shader || !playSweep) {
                    callback();
                    return;
                }
                if (sweeping) return;
                sweeping = true;
                playSweep(shader, {
                    palette: 'prism',
                    onMidpoint: function () {
                        callback();
                    },
                    onComplete: function () {
                        sweeping = false;
                    },
                });
            }

            function applyTheme() {
                document.documentElement.classList.toggle('dark', isDark);
                localStorage.setItem('ta_theme', isDark ? 'dark' : 'light');
                updateThemeBtn();
            }
            function updateThemeBtn() {
                var btn = document.getElementById('themeBtn');
                if (!btn) return;
                btn.innerHTML = isDark
                    ? '<svg viewBox="0 0 24 24"><path d="M12 7a5 5 0 100 10 5 5 0 000-10zm0-3a1 1 0 01-1-1V1a1 1 0 112 0v2a1 1 0 01-1 1zm0 18a1 1 0 01-1-1v-2a1 1 0 112 0v2a1 1 0 01-1 1zm9-9a1 1 0 01-1 1h-2a1 1 0 110-2h2a1 1 0 011 1zM6 12a1 1 0 01-1 1H3a1 1 0 110-2h2a1 1 0 011 1zm12.36-5.64a1 1 0 01-.7-.3l-1.42-1.42a1 1 0 011.41-1.41l1.42 1.42a1 1 0 01-.71 1.71zM5.76 18.24a1 1 0 01-.7-.3l-1.42-1.42a1 1 0 011.41-1.41l1.42 1.42a1 1 0 01-.71 1.71zM18.24 18.24a1 1 0 01-.71-1.71l1.42-1.42a1 1 0 011.41 1.41l-1.42 1.42a1 1 0 01-.7.3zM5.76 5.76a1 1 0 01-.71-1.71l1.42-1.42A1 1 0 017.87 4.04L6.46 5.46a1 1 0 01-.7.3z"/></svg>'
                    : '<svg viewBox="0 0 24 24"><path d="M12 3a9 9 0 109 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 01-4.4 2.26 5.403 5.403 0 01-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>';
                btn.setAttribute(
                    'aria-label',
                    isDark ? 'Switch to light mode' : 'Switch to dark mode'
                );
            }

            function applyLang() {
                var htmlRoot = document.getElementById('htmlRoot');
                if (htmlRoot) {
                    htmlRoot.setAttribute('lang', lang === 'zh' ? 'zh-CN' : 'en');
                }
                document.querySelectorAll('[data-zh]').forEach(function (el) {
                    var val = el.getAttribute('data-' + lang);
                    if (el.tagName === 'META') {
                        el.setAttribute('content', val);
                    } else {
                        el.textContent = val;
                    }
                });
                localStorage.setItem('ta_lang', lang);
                var sps = document.querySelectorAll('.sep');
                sps.forEach(function (sp, i) {
                    sp.textContent = labels[lang][i];
                });
                updateLangBtn();
            }
            function updateLangBtn() {
                var btn = document.getElementById('langBtn');
                if (btn) btn.textContent = lang === 'zh' ? 'EN' : '中';
            }

            var ctrl = document.getElementById('controls');
            var langBtn = document.createElement('button');
            langBtn.id = 'langBtn';
            langBtn.title = 'Switch language';
            langBtn.onclick = function () {
                if (sweeping) return;
                lang = lang === 'zh' ? 'en' : 'zh';
                withSweep(function () {
                    applyLang();
                });
            };
            ctrl.appendChild(langBtn);
            var themeBtn = document.createElement('button');
            themeBtn.id = 'themeBtn';
            themeBtn.title = 'Toggle dark mode';
            themeBtn.setAttribute(
                'aria-label',
                isDark ? 'Switch to light mode' : 'Switch to dark mode'
            );
            themeBtn.onclick = function () {
                if (sweeping) return;
                isDark = !isDark;
                withSweep(function () {
                    applyTheme();
                });
            };
            ctrl.appendChild(themeBtn);

            applyTheme();
            applyLang();

            // --- Countdown ---
            var target = new Date('2026-06-01T00:00:00+08:00').getTime();
            var cellH = 41.6;

            function makeCell() {
                var cell = document.createElement('div');
                cell.className = 'roll-cell';
                var strip = document.createElement('div');
                strip.className = 'roll-strip';
                for (var i = 0; i <= 9; i++) {
                    var d = document.createElement('div');
                    d.className = 'roll-digit';
                    d.textContent = i;
                    strip.appendChild(d);
                }
                cell.appendChild(strip);
                return { el: cell, strip: strip, cur: -1 };
            }

            var cells = [];
            var container = document.getElementById('cd');
            var defs = [
                { label: 0, pairs: [0, 1] },
                { label: 2, pairs: [2, 3] },
            ];
            defs.forEach(function (def) {
                var pair = document.createElement('div');
                pair.className = 'cd-pair';
                def.pairs.forEach(function (gi) {
                    var grp = document.createElement('div');
                    grp.className = 'cd-group';
                    for (var i = 0; i < 2; i++) {
                        var c = makeCell();
                        grp.appendChild(c.el);
                        cells.push(c);
                    }
                    var sp = document.createElement('span');
                    sp.className = 'sep';
                    sp.textContent = labels[lang][gi];
                    grp.appendChild(sp);
                    pair.appendChild(grp);
                });
                container.appendChild(pair);
            });

            function setCell(c, digit) {
                if (c.cur === digit) return;
                c.cur = digit;
                c.strip.style.transform = 'translateY(' + -digit * cellH + 'px)';
            }

            function tick() {
                var diff = target - Date.now();
                if (diff <= 0) {
                    cells.forEach(function (c) {
                        setCell(c, 0);
                    });
                    return;
                }
                var sec = Math.floor(diff / 1000);
                var d = Math.floor(sec / 86400),
                    h = Math.floor((sec % 86400) / 3600);
                var m = Math.floor((sec % 3600) / 60),
                    s = sec % 60;
                var pad = function (n) {
                    return [Math.floor(n / 10), n % 10];
                };
                var dd = pad(d),
                    hh = pad(h),
                    mm = pad(m),
                    ss = pad(s);
                var vals = [dd[0], dd[1], hh[0], hh[1], mm[0], mm[1], ss[0], ss[1]];
                for (var i = 0; i < 8; i++) setCell(cells[i], vals[i]);
            }

            tick();
            setInterval(tick, 1000);
        </script>
