        <style is:global>
            :root {
                --bg: #ffffff;
                --fg: #09090b;
                --muted: #71717a;
                --sep: #d4d4d8;
                --cell-bg: #f4f4f5;
                --cell-border: #e4e4e7;
            }
            .dark {
                --bg: #09090b;
                --fg: #fafafa;
                --muted: #a1a1aa;
                --sep: #3f3f46;
                --cell-bg: #18181b;
                --cell-border: #27272a;
            }
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            html,
            body {
                width: 100%;
                min-height: 100vh;
            }
            body {
                font-family:
                    'Inter',
                    -apple-system,
                    BlinkMacSystemFont,
                    sans-serif;
                background: var(--bg);
                color: var(--fg);
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                -webkit-font-smoothing: antialiased;
            }
            .wrap {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 3rem;
                padding: 2rem;
                overflow: visible;
            }
            .logo-light {
                width: 180px;
                height: auto;
            }
            .logo-dark {
                display: none;
                width: 180px;
                height: auto;
            }
            .dark .logo-light {
                display: none;
            }
            .dark .logo-dark {
                display: block;
            }
            .info {
                text-align: center;
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }
            .title {
                font-size: 2.25rem;
                font-weight: 500;
                color: var(--fg);
                letter-spacing: -0.01em;
            }
            .subtitle {
                font-size: 1rem;
                color: var(--muted);
                font-weight: 400;
                letter-spacing: 0.005em;
            }
            .countdown {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                align-items: center;
                gap: 0.6rem;
            }
            .cd-pair {
                display: flex;
                gap: 0.8rem;
            }
            .cd-group {
                display: flex;
                align-items: center;
                gap: 0.35rem;
            }
            .roll-cell {
                width: 1.8rem;
                height: 2.6rem;
                overflow: hidden;
                position: relative;
                background: var(--cell-bg);
                border: 1px solid var(--cell-border);
                border-radius: 0.375rem;
            }
            .roll-strip {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
            }
            .roll-digit {
                width: 100%;
                height: 2.6rem;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'JetBrains Mono', monospace;
                font-size: 1.125rem;
                font-weight: 500;
                font-variant-numeric: tabular-nums;
                color: var(--fg);
                user-select: none;
            }
            .sep {
                font-family: 'JetBrains Mono', monospace;
                font-size: 0.8rem;
                font-weight: 500;
                color: var(--sep);
                line-height: 2.6rem;
                text-align: center;
                user-select: none;
            }
            .gh {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 32px;
                height: 32px;
                border-radius: 50%;
                color: var(--sep);
                text-decoration: none;
                transition: color 0.2s;
            }
            .gh:hover {
                color: var(--fg);
            }
            .gh svg {
                width: 16px;
                height: 16px;
            }
            .controls {
                position: fixed;
                top: 1rem;
                right: 1rem;
                display: flex;
                gap: 0.5rem;
                z-index: 10;
                min-height: 36px;
            }
            .controls button {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 36px;
                height: 36px;
                border: 1px solid var(--cell-border);
                border-radius: 0.5rem;
                background: var(--cell-bg);
                color: var(--fg);
                font-size: 0.8rem;
                font-weight: 500;
                cursor: pointer;
                transition:
                    background 0.2s,
                    border-color 0.2s,
                    color 0.2s;
                line-height: 1;
            }
            .controls button:hover {
                border-color: var(--muted);
            }
            .controls button svg {
                width: 16px;
                height: 16px;
                fill: currentColor;
            }
            @media (max-width: 480px) {
                .wrap {
                    gap: 2rem;
                    padding: 1.25rem;
                }
                .logo-light,
                .logo-dark {
                    width: 140px;
                }
                .title {
                    font-size: 1.75rem;
                }
                .subtitle {
                    font-size: 0.875rem;
                }
                .countdown {
                    gap: 0.4rem;
                }
                .roll-cell {
                    width: 1.5rem;
                }
                .roll-digit {
                    font-size: 1rem;
                }
                .sep {
                    font-size: 0.7rem;
                }
            }
        </style>
        <script is:inline>
            (function () {
                var t = localStorage.getItem('ta_theme');
                if (
                    t === 'dark' ||
                    (!t &&
                        window.matchMedia &&
                        window.matchMedia('(prefers-color-scheme: dark)').matches)
                ) {
                    document.documentElement.classList.add('dark');
                }
            })();
        </script>
    </head>
