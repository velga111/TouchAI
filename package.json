{
    "name": "touchai-monorepo",
    "private": true,
    "version": "0.1.0",
    "description": "TouchAI monorepo",
    "author": "TouchAI Team",
    "license": "GPL-3.0-or-later",
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "dev": "pnpm --filter @touchai/desktop dev",
        "build": "pnpm --filter @touchai/desktop build",
        "preview": "pnpm --filter @touchai/desktop preview",
        "tauri": "pnpm --filter @touchai/desktop tauri",
        "site:dev": "pnpm --filter @touchai/site dev",
        "site:build": "pnpm --filter @touchai/site build",
        "site:preview": "pnpm --filter @touchai/site preview",
        "test": "pnpm --filter @touchai/desktop test",
        "test:unit": "pnpm --filter @touchai/desktop test:unit",
        "test:coverage": "pnpm --filter @touchai/desktop test:coverage",
        "test:e2e": "pnpm --filter @touchai/desktop test:e2e",
        "test:rust": "pnpm --filter @touchai/desktop test:rust",
        "test:coverage:rust": "pnpm --filter @touchai/desktop test:coverage:rust",
        "test:typecheck": "pnpm --filter @touchai/desktop test:typecheck",
        "test:ui": "pnpm --filter @touchai/desktop test:ui",
        "test:run": "pnpm --filter @touchai/desktop test:run",
        "test:pr": "pnpm --filter @touchai/desktop test:pr && pnpm --filter @touchai/site build",
        "type:check": "pnpm --filter @touchai/desktop type:check",
        "lint": "pnpm --filter @touchai/desktop lint",
        "lint:check": "pnpm --filter @touchai/desktop lint:check",
        "check": "pnpm --filter @touchai/desktop check",
        "format:check": "prettier --check . --ignore-path .prettierignore",
        "format:fix": "prettier --write . --ignore-path .prettierignore && pnpm run format:rust:fix",
        "format:rust:fix": "pnpm --filter @touchai/desktop format:rust:fix",
        "check:rust": "pnpm --filter @touchai/desktop check:rust",
        "db:generate": "pnpm --filter @touchai/desktop db:generate",
        "db:studio": "pnpm --filter @touchai/desktop db:studio",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4",
        "prettier": "3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.3",
        "vue-eslint-parser": "^10.4.0"
    },
    "pnpm": {
        "overrides": {
            "@vitest/coverage-v8": "4.1.6",
            "dompurify": "3.4.2",
            "serialize-javascript": "7.0.5"
        }
    },
    "lint-staged": {
        "apps/desktop/**/*.{js,ts,vue}": [
            "pnpm --filter @touchai/desktop exec eslint --fix",
            "prettier --write --ignore-path .prettierignore"
        ],
        "apps/site/**/*.{astro,css,js,md,mdx,ts}": [
            "prettier --write --ignore-path .prettierignore"
        ],
        "*.{json,md,html,css,yml,yaml}": [
            "prettier --write --ignore-path .prettierignore"
        ],
        "apps/desktop/src-tauri/**/*.rs": [
            "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --"
        ]
    },
    "keywords": [
        "ai",
        "desktop",
        "tauri",
        "vue",
        "productivity"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/TouchAI-org/TouchAI.git"
    },
    "bugs": {
        "url": "https://github.com/TouchAI-org/TouchAI/issues"
    },
    "homepage": "https://github.com/TouchAI-org/TouchAI#readme"
}
